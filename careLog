<!DOCTYPE html>
<html>
<head>
  <base target="_top">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Noto Sans KR', sans-serif; background: #f4f6f9; min-height: 100vh; color: #2d3748; }

    .screen { display: none; }
    .screen.active { display: block; }

    #loginScreen {
      min-height: 100vh; display: none;
      align-items: center; justify-content: center;
      padding: 20px;
      background: linear-gradient(135deg, #e8f0fe 0%, #f4f6f9 100%);
    }
    #loginScreen.active { display: flex; }

    .login-box {
      background: white; border-radius: 16px;
      padding: 36px 32px; width: 100%; max-width: 400px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    }
    .login-logo { text-align: center; margin-bottom: 28px; }
    .login-logo .icon { font-size: 40px; display: block; margin-bottom: 8px; }
    .login-logo h1 { font-size: 20px; font-weight: 700; color: #2d5be3; }
    .login-logo p { font-size: 13px; color: #888; margin-top: 4px; }

    .field { margin-bottom: 16px; }
    .field label { display: block; font-size: 12px; font-weight: 500; color: #666; margin-bottom: 6px; }
    .field input {
      width: 100%; padding: 11px 14px;
      border: 1.5px solid #e2e8f0; border-radius: 8px;
      font-size: 14px; font-family: 'Noto Sans KR', sans-serif;
      color: #2d3748; background: #fafbfc; transition: border-color 0.2s;
    }
    .field input:focus { outline: none; border-color: #2d5be3; background: white; }

    .error-msg { color: #e53e3e; font-size: 12px; margin-top: 8px; text-align: center; min-height: 18px; }

    .btn {
      width: 100%; padding: 13px; border: none; border-radius: 8px;
      font-size: 15px; font-weight: 700; font-family: 'Noto Sans KR', sans-serif;
      cursor: pointer; transition: opacity 0.15s, transform 0.1s;
    }
    .btn:active { transform: scale(0.98); }
    .btn-primary  { background: #2d5be3; color: white; margin-top: 8px; }
    .btn-success  { background: #38a169; color: white; }
    .btn-outline  { background: white; color: #666; border: 1.5px solid #e2e8f0; margin-top: 8px; }
    .btn-save     { background: #718096; color: white; margin-bottom: 8px; }

    .btn-add {
      width: 100%; padding: 10px;
      background: #ebf4ff; color: #2d5be3;
      border: 1.5px dashed #93c5fd; border-radius: 8px;
      font-size: 14px; font-family: 'Noto Sans KR', sans-serif;
      cursor: pointer; margin-top: 8px; font-weight: 500;
    }
    .btn-remove {
      padding: 4px 10px; background: #fff5f5; color: #e53e3e;
      border: 1px solid #fed7d7; border-radius: 6px; font-size: 12px;
      font-family: 'Noto Sans KR', sans-serif; cursor: pointer;
    }

    #logScreen { max-width: 580px; margin: 0 auto; padding: 20px 16px 40px; }

    .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .top-bar h2 { font-size: 18px; font-weight: 700; color: #2d3748; }
    .logout-btn {
      padding: 6px 14px; background: #f7fafc; color: #666;
      border: 1px solid #e2e8f0; border-radius: 6px; font-size: 13px;
      font-family: 'Noto Sans KR', sans-serif; cursor: pointer;
    }

    .user-banner {
      background: linear-gradient(135deg, #2d5be3, #4f7ef8);
      color: white; border-radius: 10px; padding: 14px 18px;
      margin-bottom: 16px; font-size: 14px;
      display: flex; align-items: center; gap: 10px;
    }
    .user-banner .name { font-weight: 700; font-size: 16px; }
    .user-banner .no   { font-size: 12px; opacity: 0.85; margin-top: 2px; }

    .card { background: white; border-radius: 12px; padding: 18px; margin-bottom: 14px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
    .card-title {
      font-size: 13px; font-weight: 700; color: #2d5be3;
      letter-spacing: 0.5px; margin-bottom: 14px;
      padding-bottom: 10px; border-bottom: 1px solid #f0f4ff;
    }

    .log-card { background: #f8faff; border: 1.5px solid #e8eeff; border-radius: 10px; padding: 14px; margin-bottom: 10px; }
    .log-card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
    .log-day-label { font-size: 13px; font-weight: 700; color: #2d5be3; }

    .time-row { display: flex; gap: 10px; }
    .time-row > .field { flex: 1; margin-bottom: 0; }

    .cb-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; margin-top: 4px; }
    .cb-item {
      display: flex; align-items: center; gap: 6px;
      background: white; border: 1.5px solid #e2e8f0; border-radius: 6px;
      padding: 8px 10px; cursor: pointer; transition: all 0.15s;
      font-size: 13px; color: #444;
    }
    .cb-item input[type=checkbox] { display: none; }
    .cb-item.checked { background: #ebf4ff; border-color: #2d5be3; color: #2d5be3; font-weight: 500; }
    .cb-check {
      width: 16px; height: 16px; border: 2px solid #cbd5e0;
      border-radius: 4px; display: flex; align-items: center;
      justify-content: center; flex-shrink: 0; transition: all 0.15s;
    }
    .cb-item.checked .cb-check { background: #2d5be3; border-color: #2d5be3; color: white; font-size: 10px; }

    canvas {
      width: 100%; border: 1.5px solid #e2e8f0; border-radius: 8px;
      background: white; touch-action: none; display: block;
    }
    .sign-hint { text-align: center; font-size: 12px; color: #aaa; margin-top: 6px; }

    /* 결제금액 - 최종제출 전까지 흐리게 표시 */
    .amount-notice { font-size: 12px; color: #e53e3e; margin-top: 6px; }
  </style>
</head>
<body>

<!-- ── 로그인 화면 ── -->
<div id="loginScreen" class="screen active">
  <div class="login-box">
    <div class="login-logo">
      <span class="icon">🌸</span>
      <h1>카네이션 간병</h1>
      <p>간병일지 입력 시스템</p>
    </div>
    <div class="field">
      <label>간병인 성명</label>
      <input type="text" id="loginName" placeholder="이름을 입력하세요">
    </div>
    <div class="field">
      <label>생년월일</label>
      <input type="date" id="loginBirth">
    </div>
    <p class="error-msg" id="loginError"></p>
    <button class="btn btn-primary" onclick="doLogin()">확인</button>
  </div>
</div>

<!-- ── 간병일지 입력 화면 ── -->
<div id="logScreen" class="screen">
  <div class="top-bar">
    <h2>📋 간병일지</h2>
    <button class="logout-btn" onclick="doLogout()">로그아웃</button>
  </div>

  <div class="user-banner">
    <span style="font-size:24px">👤</span>
    <div>
      <div class="name" id="bannerName"></div>
      <div class="no"   id="bannerNo"></div>
    </div>
  </div>

    <div id="editBanner" style="display:none; background:#fff3cd; border:1px solid #ffc107;
       border-radius:10px; padding:12px 16px; margin-bottom:14px; font-size:13px; color:#856404;">
    ✏️ <strong>수정 모드</strong> — 기존 제출 기록을 불러왔습니다.
    <strong>최종 제출</strong>을 누르면 수정이 완료됩니다.
  </div>


  <!-- 환자 정보 -->
  <div class="card">
    <div class="card-title">환자 정보</div>
    <div class="field">
      <label>환자 성명</label>
      <input type="text" id="patientName" placeholder="환자 이름 입력">
    </div>
    <div class="field" style="margin-bottom:0">
      <label>환자 생년월일</label>
      <input type="date" id="patientBirth">
    </div>
  </div>

  <!-- 간병 일지 -->
  <div class="card">
    <div class="card-title">간병 활동</div>
    <div id="logContainer"></div>
    <button class="btn-add" onclick="addLog()">+ 날짜 추가</button>
  </div>

  <!-- 결제금액 (최종제출 시 필수) -->
  <div class="card">
    <div class="card-title">결제 정보</div>
    <div class="field" style="margin-bottom:4px">
      <label>결제금액</label>
      <input type="text" id="amount" placeholder="숫자만 입력 (예: 500000)">
    </div>
    <p class="amount-notice">※ 최종 제출 시 반드시 입력해주세요</p>
  </div>

  <!-- 서명 -->
  <div class="card">
    <div class="card-title">환자 서명</div>
    <canvas id="signCanvas" width="520" height="160"></canvas>
    <p class="sign-hint">손가락 또는 마우스로 서명해 주세요</p>
    <button class="btn btn-outline" onclick="clearSign()" style="margin-top:10px">서명 지우기</button>
  </div>

  <button class="btn btn-save" onclick="saveData()">💾 임시 저장</button>
  <button class="btn btn-success" onclick="submitData()">✅ 최종 제출 (PDF 생성)</button>
</div>

<script>
  let currentUser = null;
  let logCount    = 0;
  let editMode    = false;  // ← 추가
  const today = new Date().toISOString().split("T")[0];
  document.getElementById("loginBirth").max = today;

  // ── 로그인 (기존 제출 기록 자동 확인) ──
  function doLogin() {
    const name  = document.getElementById("loginName").value.trim();
    const birth = document.getElementById("loginBirth").value;
    const errEl = document.getElementById("loginError");

    if (!name)  { errEl.innerText = "성명을 입력하세요."; return; }
    if (!birth) { errEl.innerText = "생년월일을 선택하세요."; return; }

    errEl.innerText = "확인 중...";

    google.script.run
      .withFailureHandler(err => { errEl.innerText = err.message; })
      .withSuccessHandler(user => {
        currentUser = user;
        document.getElementById("bannerName").innerText = user.name + " 간병인";
        document.getElementById("bannerNo").innerText   = "회원번호: " + user.memberNo;
        document.getElementById("patientBirth").max = today;
        document.getElementById("loginScreen").classList.remove("active");
        document.getElementById("logScreen").classList.add("active");

        // 기존 제출 기록 확인
        google.script.run
          .withFailureHandler(() => { if (logCount === 0) addLog(); })
          .withSuccessHandler(existing => {
            if (existing) {
              // 수정 모드: 기존 데이터 불러오기
              editMode = true;
              loadExistingData(existing);
              // 상단에 수정 모드 안내 표시
              document.getElementById("editBanner").style.display = "block";
            } else {
              editMode = false;
              document.getElementById("editBanner").style.display = "none";
              if (logCount === 0) addLog();
            }
          })
          .기존간병일지불러오기(user.memberNo);
      })
      .간병인로그인(name, birth);
  }

  // ── 기존 데이터 화면에 불러오기 ──
  function loadExistingData(existing) {
    document.getElementById("patientName").value  = existing.patientName;
    document.getElementById("patientBirth").value = existing.patientBirth.replace(/\./g, "-");
    document.getElementById("amount").value       = existing.amount;

    document.getElementById("logContainer").innerHTML = "";
    logCount = 0;

    existing.logs.forEach(log => {
      logCount++;
      const id  = "log_" + logCount;
      const div = document.createElement("div");
      div.className = "log-card";
      div.id = id;
      div.innerHTML = `
        <div class="log-card-header">
          <span class="log-day-label">${logCount}일차</span>
          <button class="btn-remove" onclick="removeLog('${id}')">삭제</button>
        </div>
        <div class="field">
          <label>간병 날짜</label>
          <input type="date" class="log-date" max="${today}" value="${log.date}">
        </div>
        <div class="time-row">
          <div class="field"><label>시작 시간</label><input type="time" class="log-start" value="${log.startTime}"></div>
          <div class="field"><label>종료 시간</label><input type="time" class="log-end" value="${log.endTime}"></div>
        </div>
        <div class="field" style="margin-bottom:8px">
          <label>주요 간병 활동</label>
          <div class="cb-grid">
            ${["식사보조","활동보조","배변보조","위생보조","기타"].map(v => `
              <label class="cb-item ${log[v] ? "checked" : ""}" onclick="toggleCb(this)">
                <input type="checkbox" class="cb" value="${v}" ${log[v] ? "checked" : ""}>
                <span class="cb-check">${log[v] ? "✓" : ""}</span>${v}
              </label>`).join("")}
          </div>
        </div>
        <div class="field" style="margin-bottom:0">
          <label>특이사항</label>
          <input type="text" class="log-note" placeholder="선택 입력" value="${log.note || ""}">
        </div>`;
      document.getElementById("logContainer").appendChild(div);
    });
  }

  function doLogout() {
    currentUser = null; logCount = 0;
    ["logContainer","loginName","loginBirth","loginError",
     "patientName","patientBirth","amount"].forEach(id => {
      const el = document.getElementById(id);
      if (el.tagName === "DIV") el.innerHTML = "";
      else el.value = "";
    });
    document.getElementById("loginError").innerText = "";
    clearSign();
    document.getElementById("logScreen").classList.remove("active");
    document.getElementById("loginScreen").classList.add("active");
  }

  // ── 날짜 카드 ──
  function addLog() {
    logCount++;
    const id  = "log_" + logCount;
    const div = document.createElement("div");
    div.className = "log-card";
    div.id = id;
    div.innerHTML = `
      <div class="log-card-header">
        <span class="log-day-label">${logCount}일차</span>
        <button class="btn-remove" onclick="removeLog('${id}')">삭제</button>
      </div>
      <div class="field">
        <label>간병 날짜</label>
        <input type="date" class="log-date" max="${today}">
      </div>
      <div class="time-row">
        <div class="field"><label>시작 시간</label><input type="time" class="log-start"></div>
        <div class="field"><label>종료 시간</label><input type="time" class="log-end"></div>
      </div>
      <div class="field" style="margin-bottom:8px">
        <label>주요 간병 활동</label>
        <div class="cb-grid">
          ${["식사보조","활동보조","배변보조","위생보조","기타"].map(v => `
            <label class="cb-item" onclick="toggleCb(this)">
              <input type="checkbox" class="cb" value="${v}">
              <span class="cb-check"></span>${v}
            </label>`).join("")}
        </div>
      </div>
      <div class="field" style="margin-bottom:0">
        <label>특이사항</label>
        <input type="text" class="log-note" placeholder="선택 입력">
      </div>`;
    document.getElementById("logContainer").appendChild(div);
  }

  function toggleCb(label) {
    const cb    = label.querySelector("input[type=checkbox]");
    cb.checked  = !cb.checked;
    const check = label.querySelector(".cb-check");
    label.classList.toggle("checked", cb.checked);
    check.innerText = cb.checked ? "✓" : "";
  }

  function removeLog(id) { document.getElementById(id).remove(); }

  // ── 서명 캔버스 ──
  const canvas = document.getElementById("signCanvas");
  const ctx    = canvas.getContext("2d");
  ctx.strokeStyle = "#1a202c"; ctx.lineWidth = 2; ctx.lineCap = "round";
  let drawing = false;

  function getPos(e) {
    const rect = canvas.getBoundingClientRect();
    const sx = canvas.width / rect.width, sy = canvas.height / rect.height;
    const cx = e.touches ? e.touches[0].clientX : e.clientX;
    const cy = e.touches ? e.touches[0].clientY : e.clientY;
    return { x: (cx - rect.left) * sx, y: (cy - rect.top) * sy };
  }
  canvas.addEventListener("mousedown",  e => { drawing = true; ctx.beginPath(); const p = getPos(e); ctx.moveTo(p.x, p.y); });
  canvas.addEventListener("mousemove",  e => { if (!drawing) return; const p = getPos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); });
  canvas.addEventListener("mouseup",    () => drawing = false);
  canvas.addEventListener("mouseleave", () => drawing = false);
  canvas.addEventListener("touchstart", e => { e.preventDefault(); drawing = true; ctx.beginPath(); const p = getPos(e); ctx.moveTo(p.x, p.y); }, { passive: false });
  canvas.addEventListener("touchmove",  e => { e.preventDefault(); if (!drawing) return; const p = getPos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); }, { passive: false });
  canvas.addEventListener("touchend",   () => drawing = false);
  function clearSign() { ctx.clearRect(0, 0, canvas.width, canvas.height); }

  // ── 공통 데이터 수집 ──
  function collectData(requireAmount) {
    const patientName  = document.getElementById("patientName").value.trim();
    const patientBirth = document.getElementById("patientBirth").value;
    const amount       = document.getElementById("amount").value.trim();

    if (!patientName)  { alert("환자 성명을 입력하세요."); return null; }
    if (!patientBirth) { alert("환자 생년월일을 선택하세요."); return null; }
    if (requireAmount && !amount) { alert("결제금액을 입력하세요."); return null; }

    const cards = document.querySelectorAll(".log-card");
    if (cards.length === 0) { alert("간병 일지를 1개 이상 추가하세요."); return null; }

    let logs = [], valid = true;
    cards.forEach(card => {
      const date = card.querySelector(".log-date").value;
      const startTime = card.querySelector(".log-start").value;
      const endTime   = card.querySelector(".log-end").value;
      const note      = card.querySelector(".log-note").value;
      if (!date || !startTime || !endTime) { valid = false; return; }
      const log = { date, startTime, endTime, note,
        식사보조: false, 활동보조: false, 배변보조: false, 위생보조: false, 기타: false };
      card.querySelectorAll(".cb:checked").forEach(cb => log[cb.value] = true);
      logs.push(log);
    });
    if (!valid) { alert("모든 날짜의 날짜와 시간을 입력하세요."); return null; }

    return {
      memberNo:      currentUser.memberNo,
      caregiverName: currentUser.name,
      registerDate:  currentUser.registerDate,
      patientName,
      patientBirth:  patientBirth.replace(/-/g, "."),
      amount,
      logs,
      signature: canvas.toDataURL("image/png")
    };
  }

  // ── 임시 저장 (결제금액 불필요) ──
  function saveData() {
    const payload = collectData(false);
    if (!payload) return;
    google.script.run
      .withFailureHandler(err => alert("오류: " + err.message))
      .withSuccessHandler(() => alert("임시 저장되었습니다.\추후 작성 후, 퇴원날짜에 맞춰 최종 제출해주세요."))
      .간병일지저장(payload, "save");
  }

  // ── 최종 제출 (결제금액 필수, 서명 필수, PDF 생성) ──
  function submitData() {
    const payload = collectData(true);
    if (!payload) return;

    const pixels = ctx.getImageData(0, 0, canvas.width, canvas.height).data;
    if (!pixels.some(v => v !== 0)) { alert("환자 서명을 받아주세요."); return; }

    const confirmMsg = editMode
      ? "수정 제출하면 기존 PDF가 삭제되고 새로 생성됩니다.\n계속하시겠습니까?"
      : "최종 제출하면 PDF가 생성됩니다.\n간병일지 작성이 모두 완료되었나요?\n(제출 후 수정은 재로그인 후 가능합니다)";

    if (!confirm(confirmMsg)) return;

    const handler = editMode ? "간병일지수정" : "간병일지저장";
    const args    = editMode ? [payload] : [payload, "submit"];

    google.script.run
      .withFailureHandler(err => alert("오류: " + err.message))
      .withSuccessHandler(() => {
        alert(editMode ? "수정이 완료되었습니다!" : "제출이 완료되었습니다. 감사합니다!");
        editMode = false;
        document.getElementById("editBanner").style.display = "none";
      })
      [handler](...args);
  }
</script>
</body>
</html>
